{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "jsx": "react-jsx",

    "declaration": true,
    "declarationDir": "dist/types",   
    "emitDeclarationOnly": true,      
    "rootDir": "src",

    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}